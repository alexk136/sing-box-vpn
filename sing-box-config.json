{
  "log": {
    "level": "info",
    "output": "/var/log/sing-box.log",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "dns-remote",
        "address": "https://1.1.1.1/dns-query",
        "address_resolver": "dns-direct",
        "detour": "proxy-out"
      },
      {
        "tag": "dns-direct",
        "address": "https://1.1.1.1/dns-query",
        "detour": "direct"
      },
      {
        "tag": "dns-lan",
        "address": "udp://192.168.0.1:53",
        "detour": "direct"
      },
      {
        "type": "hosts",
        "tag": "dns-system-hosts"
      },
      {
        "tag": "dns-local",
        "address": "local",
        "detour": "direct"
      }
    ],
    "rules": [
      {
        "domain": "cp.cloudflare.com",
        "server": "dns-remote"
      },
      {
        "domain_suffix": ".local",
        "server": "dns-lan"
      },
      {
        "domain_suffix": ".ru",
        "server": "dns-direct"
      }
    ],
    "final": "dns-remote",
    "strategy": "prefer_ipv4",
    "independent_cache": true
  },
  "inbounds": [
    {
      "type": "tproxy",
      "tag": "tproxy-in",
      "listen": "::",
      "listen_port": 12335
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "::",
      "listen_port": 12334
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "select",
      "outbounds": ["proxy-out", "direct"],
      "default": "proxy-out"
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "direct",
      "tag": "proxy-out"
    }
  ],
  "route": {
    "default_domain_resolver": "dns-direct",
    "rule_set": [
      {
        "type": "local",
        "tag": "private-domains",
        "format": "source",
        "path": "/etc/sing-box/private-domains.txt"
      }
    ],
    "rules": [
      {
        "action": "sniff"
      },
      {
        "port": 53,
        "action": "hijack-dns"
      },
      {
        "port": 9090,
        "ip_cidr": [
          "127.0.0.0/8",
          "::1/128"
        ],
        "action": "reject"
      },
      {
        "action": "resolve",
        "server": "dns-system-hosts",
        "rule_set": "private-domains"
      },
      {
        "action": "resolve",
        "server": "dns-lan",
        "rule_set": "private-domains"
      },
      {
        "rule_set": "private-domains",
        "outbound": "direct"
      },
      {
        "domain_suffix": ".ru",
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "ip_cidr": [
          "fc00::/7",
          "fe80::/10",
          "100::/64",
          "2001:db8::/32"
        ],
        "outbound": "direct"
      }
    ],
    "final": "proxy-out",
    "auto_detect_interface": true
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "default_mode": "rule"
    }
  }
}
